<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <!-- Background gradient overlay -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#CC000000" />

    <!-- Caller Photo -->
    <de.hdodenhof.circleimageview.CircleImageView
        android:id="@+id/ivCallerPhoto"
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="120dp"
        android:src="@drawable/ic_default_avatar"
        android:layout_above="@+id/tvCallerName" />

    <!-- Caller Name -->
    <TextView
        android:id="@+id/tvCallerName"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="280dp"
        android:text="Caller Name"
        android:textColor="@android:color/white"
        android:textSize="24sp"
        android:textStyle="bold" />

    <!-- Service Title -->
    <TextView
        android:id="@+id/tvServiceTitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvCallerName"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="12dp"
        android:text="For: Service Name"
        android:textColor="#CCCCCC"
        android:textSize="16sp" />

    <!-- Incoming Call Label -->
    <TextView
        android:id="@+id/tvIncomingLabel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_below="@id/tvServiceTitle"
        android:layout_centerHorizontal="true"
        android:layout_marginTop="40dp"
        android:text="Incoming GoProx Call..."
        android:textColor="#88FFFFFF"
        android:textSize="14sp" />

    <!-- Buttons Container -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="80dp"
        android:gravity="center"
        android:orientation="horizontal">

        <!-- Decline Button -->
        <ImageButton
            android:id="@+id/btnDecline"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginEnd="40dp"
            android:background="@drawable/bg_decline_call_button"
            android:src="@drawable/ic_call_end"
            android:contentDescription="Decline" />

        <!-- Accept Button -->
        <ImageButton
            android:id="@+id/btnAccept"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginStart="40dp"
            android:background="@drawable/bg_accept_call_button"
            android:src="@drawable/ic_call"
            android:contentDescription="Accept" />

    </LinearLayout>

</RelativeLayout>