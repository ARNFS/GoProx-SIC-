<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    android:keepScreenOn="true">

    <!-- Удалённое видео -->
    <FrameLayout
        android:id="@+id/remoteVideoContainer"
        android:layout_width="match_parent"
        android:layout_height="match_parent">

        <org.webrtc.SurfaceViewRenderer
            android:id="@+id/remoteVideoView"
            android:layout_width="match_parent"
            android:layout_height="match_parent" />

    </FrameLayout>

    <!-- Локальное видео -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/localVideoView"
        android:layout_width="120dp"
        android:layout_height="180dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:elevation="8dp"
        android:foreground="@drawable/bg_video_border" />

    <!-- Статус -->
    <TextView
        android:id="@+id/tvCallStatus"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:text="Calling..."
        android:textColor="#FFFFFF"
        android:textSize="18sp"
        android:textStyle="bold"
        android:visibility="gone" />

    <!-- Панель управления -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="40dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btnToggleMic"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_call_button"
            android:src="@drawable/ic_mic_on"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btnToggleCamera"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_call_button"
            android:src="@drawable/ic_camera_on"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btnFlipCamera"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_call_button"
            android:src="@drawable/ic_flip_camera"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btnToggleSpeaker"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_call_button"
            android:src="@drawable/ic_speaker_off"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btnEndCall"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_end_call_button"
            android:src="@drawable/ic_call_end"
            android:tint="#FFFFFF" />

    </LinearLayout>

</RelativeLayout>