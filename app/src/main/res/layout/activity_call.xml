<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000">

    <FrameLayout
        android:id="@+id/remote_video_container"
        android:layout_width="match_parent"
        android:layout_height="match_parent" />

    <FrameLayout
        android:id="@+id/local_video_container"
        android:layout_width="120dp"
        android:layout_height="180dp"
        android:layout_alignParentTop="true"
        android:layout_alignParentEnd="true"
        android:layout_marginTop="16dp"
        android:layout_marginEnd="16dp"
        android:background="#80000000" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true"
        android:layout_marginBottom="40dp"
        android:gravity="center"
        android:orientation="horizontal">

        <ImageButton
            android:id="@+id/btn_toggle_mic"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_call_button"
            android:src="@drawable/ic_mic_on"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_end_call"
            android:layout_width="70dp"
            android:layout_height="70dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_end_call_button"
            android:src="@drawable/ic_call_end"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_toggle_camera"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_call_button"
            android:src="@drawable/ic_camera_on"
            android:tint="#FFFFFF" />

        <ImageButton
            android:id="@+id/btn_share_call"
            android:layout_width="60dp"
            android:layout_height="60dp"
            android:layout_marginHorizontal="8dp"
            android:background="@drawable/bg_call_button"
            android:src="@drawable/ic_share"
            android:tint="#FFFFFF" />

    </LinearLayout>

</RelativeLayout>