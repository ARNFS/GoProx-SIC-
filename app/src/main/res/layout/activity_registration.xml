<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@android:color/white">

    <LinearLayout
        android:id="@+id/centerContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent">

        <TextView
            android:id="@+id/tvRegisterTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Register to GoProx"
            android:textSize="22sp"
            android:textStyle="bold"
            android:textColor="@android:color/black"
            android:layout_marginBottom="18dp"/>

        <!-- Google -->
        <Button
            android:id="@+id/btnGoogle"
            android:layout_width="260dp"
            android:layout_height="48dp"
            android:text="Continue via Google"
            android:textColor="@android:color/white"
            android:backgroundTint="#4285F4"
            android:layout_marginBottom="12dp"/>

        <!-- Phone -->
        <Button
            android:id="@+id/btnPhone"
            android:layout_width="260dp"
            android:layout_height="48dp"
            android:text="Via Phone Number"
            android:textColor="@android:color/white"
            android:backgroundTint="#008577"
            android:layout_marginBottom="12dp"/>

        <EditText
            android:id="@+id/etPhone"
            android:layout_width="250dp"
            android:layout_height="50dp"
            android:hint="+374xxxxxxxx"
            android:inputType="phone"
            android:visibility="gone"/>

        <!-- Loader for all -->
        <!-- activity_registration.xml-ի մեջ phone input-ի տակ -->
        <ProgressBar
            android:id="@+id/pbPhoneVerification"
            style="?android:attr/progressBarStyle"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:visibility="gone"
            android:layout_gravity="center"
            android:layout_marginBottom="12dp"/>
        <!-- Email -->
        <Button
            android:id="@+id/btnEmail"
            android:layout_width="260dp"
            android:layout_height="48dp"
            android:text="Via E-mail"
            android:textColor="@android:color/white"
            android:backgroundTint="#FF5722"
            android:layout_marginBottom="12dp"/>
        <ProgressBar
            android:id="@+id/pbLoading"
            style="?android:attr/progressBarStyleLarge"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:visibility="gone"
            android:layout_gravity="center"/>
        <EditText
            android:id="@+id/etEmail"
            android:layout_width="260dp"
            android:layout_height="48dp"
            android:hint="name@example.com"
            android:inputType="textEmailAddress"
            android:visibility="gone"
            android:padding="12dp"
            android:textColor="@android:color/black"
            android:background="@android:color/transparent"
            android:layout_marginBottom="12dp"/>
    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>